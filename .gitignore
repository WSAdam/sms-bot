# sms-bot project additions
.DS_Store
# Anchored to root so these ignore the root credentials/env dirs only — NOT
# the canonical src/ folders (rune shape-checker layout): an unanchored `data/`
# hid every src/<module>/domain/data/, and an unanchored `env/` hid
# src/core/business/env/.
/data/
!/data/*.example
/env/
!/env/example
*.local.json
