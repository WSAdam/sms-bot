{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "deno run -A --env-file=env/local npm:vite",
    "start:dev": "deno run -A --env-file=env/local npm:vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "tunnel": "deno run -A --env-file=env/local scripts/tunnel.ts",
    "test": "deno test -A --parallel tests/unit",
    "test:emulator": "deno test -A --parallel tests/emulator",
    "test:all": "deno task test && deno task test:emulator",
    "migrate": "deno run -A --env-file=env/local scripts/migrate-kv-to-firestore.ts",
    "dedupe-conversations": "deno run -A --env-file=env/local scripts/dedupe-conversations.ts",
    "shape-check": "deno run -A scripts/shape-check.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "@shared/": "./shared/",
    "@tests/": "./tests/",
    "firebase-admin": "npm:firebase-admin@^12.7.0",
    "firebase-admin/firestore": "npm:firebase-admin@^12.7.0/firestore",
    "firebase-admin/app": "npm:firebase-admin@^12.7.0/app",
    "postmark": "npm:postmark@^4.0.5",
    "@std/assert": "jsr:@std/assert@^1.0.7",
    "@std/cli": "jsr:@std/cli@^1.0.7",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/testing": "jsr:@std/testing@^1.0.4"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
